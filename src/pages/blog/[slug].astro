---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((candidate) => candidate.id !== post.id)
  .map((candidate) => ({
    post: candidate,
    sharedTags: candidate.data.tags.filter((tag: string) => post.data.tags.includes(tag)).length,
  }))
  .sort(
    (a, b) =>
      b.sharedTags - a.sharedTags ||
      new Date(b.post.data.date).getTime() - new Date(a.post.data.date).getTime()
  )
  .slice(0, 2)
  .map((item) => item.post);

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-NZ', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date,
  "dateModified": post.data.updatedDate ?? post.data.date,
  "author": { "@type": "Person", "name": "Jan Medina", "url": "https://janbmedina.com" },
  "publisher": { "@type": "Person", "name": "Jan Medina" },
  "url": `https://janbmedina.com/blog/${post.id}/`,
  "mainEntityOfPage": `https://janbmedina.com/blog/${post.id}/`,
  "keywords": post.data.tags.join(', '),
  ...(post.data.category ? { "articleSection": post.data.category } : {})
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} — Jan Medina</title>
  <meta name="description" content={post.data.description} />
  <link rel="canonical" href={`https://janbmedina.com/blog/${post.id}/`} />
  <link rel="icon" type="image/png" href="/profile.png" />

  <meta property="og:title" content={`${post.data.title} — Jan Medina`} />
  <meta property="og:description" content={post.data.description} />
  <meta property="og:image" content="https://janbmedina.com/profile.png" />
  <meta property="og:url" content={`https://janbmedina.com/blog/${post.id}/`} />
  <meta property="og:type" content="article" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${post.data.title} — Jan Medina`} />
  <meta name="twitter:description" content={post.data.description} />
  <meta name="twitter:image" content="https://janbmedina.com/profile.png" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
      background-color: #0a0a0a;
      color: #d4d4d4;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; }

    .container {
      max-width: 42rem;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }

    @media (min-width: 768px) {
      .container { padding: 6rem 2rem; }
    }

    /* Header */
    .prompt {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 2rem;
    }

    .prompt a {
      color: #555;
      transition: color 0.2s;
    }

    .prompt a:hover { color: #4ade80; }

    .post-header {
      margin-bottom: 3rem;
    }

    .post-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #4ade80;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    @media (min-width: 768px) {
      .post-header h1 { font-size: 2rem; }
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }

    .post-date {
      font-size: 0.8125rem;
      color: #555;
    }

    .post-tag {
      font-size: 0.6875rem;
      font-weight: 600;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      background: rgba(74, 222, 128, 0.1);
      color: #4ade80;
      border: 1px solid rgba(74, 222, 128, 0.2);
    }

    .post-tag.category {
      color: #93c5fd;
      background: rgba(96, 165, 250, 0.1);
      border-color: rgba(96, 165, 250, 0.2);
    }

    .post-updated {
      font-size: 0.75rem;
      color: #777;
    }

    .divider {
      width: 100%;
      height: 1px;
      background: #222;
    }

    /* Prose — dark terminal style */
    .prose {
      font-size: 0.9375rem;
      color: #d4d4d4;
      line-height: 1.8;
    }

    .prose h2 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #4ade80;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
    }

    .prose h3 {
      font-size: 1.0625rem;
      font-weight: 700;
      color: #e0e0e0;
      margin-top: 2rem;
      margin-bottom: 0.5rem;
    }

    .prose p {
      margin-bottom: 1.25rem;
    }

    .prose a {
      color: #4ade80;
      text-decoration: underline;
      text-underline-offset: 2px;
      transition: color 0.2s;
    }

    .prose a:hover { color: #6ee7a0; }

    .prose strong { color: #e0e0e0; font-weight: 700; }
    .prose em { color: #bbb; }

    .prose ul, .prose ol {
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
    }

    .prose li {
      margin-bottom: 0.375rem;
    }

    .prose li::marker { color: #4ade80; }

    .prose blockquote {
      border-left: 3px solid #4ade80;
      padding-left: 1rem;
      color: #999;
      margin-bottom: 1.25rem;
      font-style: italic;
    }

    .prose code {
      background: #1a1a1a;
      padding: 0.125rem 0.375rem;
      border-radius: 3px;
      font-size: 0.875rem;
      color: #4ade80;
    }

    .prose pre {
      background: #111;
      border: 1px solid #222;
      border-radius: 6px;
      padding: 1rem 1.25rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .prose pre code {
      background: none;
      padding: 0;
      border-radius: 0;
      font-size: 0.8125rem;
      color: #d4d4d4;
    }

    .prose img {
      max-width: 100%;
      border-radius: 6px;
      border: 1px solid #222;
      margin: 1.5rem 0;
    }

    .prose hr {
      border: none;
      border-top: 1px solid #222;
      margin: 2rem 0;
    }

    /* Footer */
    .post-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid #222;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: #555;
      transition: color 0.2s;
    }

    .back-link:hover { color: #4ade80; }

    .related-posts {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .related-heading {
      font-size: 0.875rem;
      font-weight: 700;
      color: #4ade80;
      margin-bottom: 0.25rem;
    }

    .related-card {
      display: block;
      padding: 0.875rem 1rem;
      border: 1px solid #222;
      border-radius: 4px;
      color: #d4d4d4;
      transition: background 0.15s;
    }

    .related-card:hover { background: #141414; }

    .related-title {
      font-size: 0.875rem;
      font-weight: 700;
      color: #e0e0e0;
      margin-bottom: 0.25rem;
    }

    .related-card:hover .related-title { color: #4ade80; }

    .related-desc {
      font-size: 0.8125rem;
      color: #888;
      line-height: 1.6;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Breadcrumb prompt -->
    <div class="prompt">
      <a href="/">jan</a>@<a href="/blog">blog</a> ~/posts %
    </div>

    <!-- Post header -->
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span class="post-date">{formatDate(post.data.date)}</span>
        {post.data.updatedDate && (
          <span class="post-updated">updated {formatDate(post.data.updatedDate)}</span>
        )}
        {post.data.category && (
          <span class="post-tag category">{post.data.category}</span>
        )}
        {post.data.tags.map((tag: string) => (
          <span class="post-tag">{tag}</span>
        ))}
      </div>
      <div class="divider"></div>
    </header>

    <!-- Post content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Back -->
    <div class="post-footer">
      {relatedPosts.length > 0 && (
        <div class="related-posts">
          <div class="related-heading">&gt; ls related-posts/</div>
          {relatedPosts.map((relatedPost) => (
            <a href={`/blog/${relatedPost.id}/`} class="related-card">
              <div class="related-title">{relatedPost.data.title}</div>
              <p class="related-desc">{relatedPost.data.description}</p>
            </a>
          ))}
        </div>
      )}
      <a href="/blog" class="back-link">&larr; cd ../blog</a>
    </div>
  </div>
</body>
</html>
